APP_NAME="perssonal_assistant_agent"
APP_VERSION="0.1"


FILE_ALLOWED_TYPES= ["text/plain","application/pdf"]
FILE_MAX_SIZE=10
FILE_DEFAULT_CHUNK_SIZE=512000 # 512KB

MONGODB_URL= "mongodb://admin:admin@localhost:27017"
MONGODB_DATABASE= "rag_database"

# ========================= LLM Config =========================
# GENERATION_BACKEND = "OPENAI"
GENERATION_BACKEND="GROQ"
EMBEDDING_BACKEND = "COHERE"

OPENAI_API_KEY=""
OPENAI_API_URL=
COHERE_API_KEY=""
GOOGLE_API_KEY =""
GROQ_API_KEY = ""


GENERATION_MODEL_ID="llama-3.3-70b-versatile"
EMBEDDING_MODEL_ID="embed-multilingual-light-v3.0"
EMBEDDING_MODEL_SIZE=384

INPUT_DEFAULT_MAX_CHARACTERS=4096
GENERATION_DEFAULT_MAX_TOKENS=2048
GENERATION_DEFAULT_TEMPERATURE=0.1





# ========================= Vector DB Config =========================
VECTOR_DB_BACKEND = "QDRANT"
VECTOR_DB_PATH = "qdrant_db"
VECTOR_DB_DISTANCE_METHOD = "cosine"


# Required for vector store (optional - falls back to local)
PINECONE_API_KEY=""
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=

# Optional: LangSmith for tracing

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT=""

# ─── Security ─────────────────────────────────────────────────────────────────
# API Key for authentication (leave empty to disable)
API_KEY=

# ─── Configuration ──────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Database path
# DB_PATH=rag_assistant.db
